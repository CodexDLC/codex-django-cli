services:
  db:
    image: postgres:16-alpine
    container_name: {{ project_name }}_test-db
    ports:
      - "5433:5432"
    volumes:
      - postgres_test_data:/var/lib/postgresql/data
    environment:
      - POSTGRES_DB={{ project_name }}_db
      - POSTGRES_USER={{ project_name }}_user
      - POSTGRES_PASSWORD=dev_password
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U {{ project_name }}_user -d {{ project_name }}_db"]
      interval: 5s
      timeout: 3s
      retries: 10
    networks:
      - {{ project_name }}_test-network

  redis:
    image: redis:7-alpine
    container_name: {{ project_name }}_test-redis
    env_file:
      - ../.env
    command: >
      sh -c "redis-server --requirepass $${REDIS_PASSWORD} --appendonly yes"
    ports:
      - "6381:6379"
    volumes:
      - redis_test_data:/data
    healthcheck:
      test: ["CMD", "sh", "-c", "REDISCLI_AUTH=${REDIS_PASSWORD} redis-cli ping"]
      interval: 5s
      timeout: 3s
      retries: 10
    restart: unless-stopped
    networks:
      - {{ project_name }}_test-network

  backend:
    build:
      context: ..
      dockerfile: deploy/backend/Dockerfile
    container_name: {{ project_name }}_test-backend
    ports:
      - "8001:8000"
    env_file:
      - ../.env
    environment:
      - POSTGRES_HOST=db
      - POSTGRES_PORT=5432
      - REDIS_HOST=redis
      - REDIS_PORT=6379
      - ENVIRONMENT=testing
    volumes:
      - ../src/{{ project_name }}:/app
      - media_test_volume:/app/media
      - static_test_volume:/app/staticfiles
      - logs_test_volume:/app/logs
    depends_on:
      db:
        condition: service_healthy
      redis:
        condition: service_healthy
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8000/api/v1/health"]
      interval: 10s
      timeout: 5s
      retries: 10
      start_period: 15s
    restart: unless-stopped
    networks:
      - {{ project_name }}_test-network

volumes:
  postgres_test_data:
  redis_test_data:
  media_test_volume:
  static_test_volume:
  logs_test_volume:

networks:
  {{ project_name }}_test-network:
    name: {{ project_name }}_test-network
    driver: bridge
