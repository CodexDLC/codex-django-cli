services:
  db:
    image: postgres:16-alpine
    container_name: ${CONTAINER_PREFIX:-{{ project_name }}}-db
    ports:
      - "5432:5432"
    volumes:
      - postgres_data:/var/lib/postgresql/data
    environment:
      - POSTGRES_DB={{ project_name }}_db
      - POSTGRES_USER={{ project_name }}_user
      - POSTGRES_PASSWORD=dev_password
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U {{ project_name }}_user -d {{ project_name }}_db"]
      interval: 10s
      timeout: 5s
      retries: 5
    networks:
      - {{ project_name }}-network

  redis:
    image: redis:7-alpine
    container_name: ${CONTAINER_PREFIX:-{{ project_name }}}-redis
    env_file:
      - ../.env
    command: >
      sh -c "redis-server --requirepass $${REDIS_PASSWORD} --appendonly yes"
    ports:
      - "6380:6379"
    volumes:
      - redis-data:/data
    healthcheck:
      test: ["CMD", "sh", "-c", "REDISCLI_AUTH=${REDIS_PASSWORD} redis-cli ping"]
      interval: 10s
      timeout: 5s
      retries: 3
    restart: unless-stopped
    networks:
      - {{ project_name }}-network

  backend:
    build:
      context: ..
      dockerfile: deploy/backend/Dockerfile
    container_name: ${CONTAINER_PREFIX:-{{ project_name }}}-backend
    ports:
      - "8000:8000"
    env_file:
      - ../.env
    volumes:
      - ../src/{{ project_name }}:/app
      - media_volume:/app/media
      - static_volume:/app/staticfiles
      - logs_volume:/app/logs
    depends_on:
      db:
        condition: service_healthy
      redis:
        condition: service_healthy
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8000/api/v1/health"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 10s
    restart: unless-stopped
    networks:
      - {{ project_name }}-network
{% if with_worker %}

  worker:
    build:
      context: ..
      dockerfile: deploy/worker/Dockerfile
    container_name: ${CONTAINER_PREFIX:-{{ project_name }}}-worker
    command: arq src.workers.notification_worker.worker.WorkerSettings
    env_file:
      - ../.env
    volumes:
      - ../src/workers:/app/src/workers:ro
      - logs_volume:/app/logs
    restart: unless-stopped
    depends_on:
      redis:
        condition: service_healthy
      backend:
        condition: service_healthy
    networks:
      - {{ project_name }}-network
{% endif %}
{% if with_bot %}

  bot:
    build:
      context: ..
      dockerfile: deploy/bot/Dockerfile
    container_name: ${CONTAINER_PREFIX:-{{ project_name }}}-bot
    env_file:
      - ../.env
    restart: unless-stopped
    depends_on:
      redis:
        condition: service_healthy
      backend:
        condition: service_healthy
    networks:
      - {{ project_name }}-network
{% endif %}

  nginx:
    build:
      context: ..
      dockerfile: deploy/nginx/Dockerfile.local
    container_name: ${CONTAINER_PREFIX:-{{ project_name }}}-nginx
    ports:
      - "8080:80"
    volumes:
      - media_volume:/app/media:ro
      - static_volume:/app/staticfiles:ro
    depends_on:
      backend:
        condition: service_healthy
    restart: unless-stopped
    networks:
      - {{ project_name }}-network

  mailpit:
    image: axllent/mailpit:latest
    container_name: ${CONTAINER_PREFIX:-{{ project_name }}}-mailpit
    ports:
      - "8025:8025"
      - "1025:1025"
    environment:
      - MP_MAX_MESSAGES=500
      - MP_SMTP_AUTH_ACCEPT_ANY=1
      - MP_SMTP_AUTH_ALLOW_INSECURE=1
    restart: unless-stopped
    networks:
      - {{ project_name }}-network

volumes:
  postgres_data:
  redis-data:
  media_volume:
  static_volume:
  logs_volume:

networks:
  {{ project_name }}-network:
    name: ${CONTAINER_PREFIX:-{{ project_name }}}-network
    driver: bridge
