{% raw %}name: CI Main (Quality, Tests & Build)

on:
  workflow_dispatch:
  pull_request:
    branches: [ main ]

jobs:
  quality-and-tests:
    name: Quality (Lint, Types, Security, Tests)
    runs-on: ubuntu-latest

    services:
      mailpit:
        image: axllent/mailpit:latest
        ports:
          - 1025:1025
      redis:
        image: redis:7-alpine
        ports:
          - 6379:6379

    steps:
      - uses: actions/checkout@v4

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: "{% endraw %}{{ python_version }}{% raw %}"
          cache: pip
          cache-dependency-path: pyproject.toml

      - name: Install dependencies
        run: |
          python -m pip install --upgrade pip
          python -m pip install -e ".[dev]"

      - name: Run Ruff (Lint & Format)
        run: |
          python -m ruff check src/
          python -m ruff format src/ --check

      - name: Run Mypy (Types)
        run: python -m mypy src/

      - name: Security Audit (pip-audit)
        run: python -m pip_audit --local

      - name: Security SAST (Bandit)
        run: python -m bandit -r src/ -ll

      - name: Run Pytest
        env:
          SECRET_KEY: "test_secret_key_for_ci"
          ENVIRONMENT: "testing"
          REDIS_HOST: "localhost"
          REDIS_PORT: "6379"
        run: python -m pytest

  build-base:
    name: Build Base Image
    runs-on: ubuntu-latest
    permissions:
      contents: read
      packages: write
    steps:
      - uses: actions/checkout@v4

      - name: Set up Docker Buildx
        uses: docker/setup-buildx-action@v3

      - name: Log in to GHCR
        uses: docker/login-action@v3
        with:
          registry: ghcr.io
          username: ${{ github.actor }}
          password: ${{ secrets.GITHUB_TOKEN }}

      - name: Lowercase repo name
        run: echo "REPO_LOWER=${GITHUB_REPOSITORY,,}" >> $GITHUB_ENV

      - name: Build and Push Base Image
        uses: docker/build-push-action@v5
        with:
          context: .
          file: deploy/docker/base.Dockerfile
          push: true
          tags: |
            ghcr.io/${{ env.REPO_LOWER }}-base:latest
          cache-from: type=registry,ref=ghcr.io/${{ env.REPO_LOWER }}-base:buildcache
          cache-to: type=registry,ref=ghcr.io/${{ env.REPO_LOWER }}-base:buildcache,mode=max

  build-project:
    name: Build Project Backend
    needs: build-base
    runs-on: ubuntu-latest
    permissions:
      contents: read
      packages: write
    steps:
      - uses: actions/checkout@v4

      - name: Set up Docker Buildx
        uses: docker/setup-buildx-action@v3

      - name: Log in to GHCR
        uses: docker/login-action@v3
        with:
          registry: ghcr.io
          username: ${{ github.actor }}
          password: ${{ secrets.GITHUB_TOKEN }}

      - name: Lowercase repo name
        run: echo "REPO_LOWER=${GITHUB_REPOSITORY,,}" >> $GITHUB_ENV

      - name: Build and Push Backend
        uses: docker/build-push-action@v5
        with:
          context: .
          file: deploy/docker/django.Dockerfile
          push: true
          build-args: |
            BASE_IMAGE=ghcr.io/${{ env.REPO_LOWER }}-base:latest
            PROJECT_ID={% endraw %}{{ project_name }}{% raw %}
          tags: |
            ghcr.io/${{ env.REPO_LOWER }}-{% endraw %}{{ project_name }}{% raw %}-backend:latest
          cache-from: type=registry,ref=ghcr.io/${{ env.REPO_LOWER }}-{% endraw %}{{ project_name }}{% raw %}-backend:buildcache
          cache-to: type=registry,ref=ghcr.io/${{ env.REPO_LOWER }}-{% endraw %}{{ project_name }}{% raw %}-backend:buildcache,mode=max
{% endraw %}
{% if with_worker %}
{% raw %}
  build-worker:
    name: Build Shared Worker
    needs: build-base
    runs-on: ubuntu-latest
    permissions:
      contents: read
      packages: write
    steps:
      - uses: actions/checkout@v4

      - name: Set up Docker Buildx
        uses: docker/setup-buildx-action@v3

      - name: Log in to GHCR
        uses: docker/login-action@v3
        with:
          registry: ghcr.io
          username: ${{ github.actor }}
          password: ${{ secrets.GITHUB_TOKEN }}

      - name: Lowercase repo name
        run: echo "REPO_LOWER=${GITHUB_REPOSITORY,,}" >> $GITHUB_ENV

      - name: Build and Push Worker
        uses: docker/build-push-action@v5
        with:
          context: .
          file: deploy/worker/Dockerfile
          push: true
          tags: ghcr.io/${{ env.REPO_LOWER }}-worker:latest
          cache-from: type=registry,ref=ghcr.io/${{ env.REPO_LOWER }}-worker:buildcache
          cache-to: type=registry,ref=ghcr.io/${{ env.REPO_LOWER }}-worker:buildcache,mode=max
{% endraw %}
{% endif %}
