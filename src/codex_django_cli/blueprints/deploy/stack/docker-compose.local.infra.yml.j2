services:
  # --- Shared Redis (Local) ---
  redis:
    image: redis:7-alpine
    container_name: {{ cluster_name }}-cluster-redis-local
    ports:
      - "6379:6379"
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 5s
      timeout: 3s
      retries: 5
    networks:
      - {{ cluster_name }}-cluster-local-network

  # --- Shared Postgres (Local) ---
  db:
    image: postgres:16-alpine
    container_name: {{ cluster_name }}-cluster-db-local
    environment:
      POSTGRES_DB: ${POSTGRES_DB:-{{ cluster_name }}_cluster}
      POSTGRES_USER: ${POSTGRES_USER:-postgres}
      POSTGRES_PASSWORD: ${POSTGRES_PASSWORD:-postgres}
    ports:
      - "5432:5432"
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U postgres"]
      interval: 5s
      timeout: 3s
      retries: 5
    networks:
      - {{ cluster_name }}-cluster-local-network
{% if with_worker %}

  # --- Shared Worker (Local) ---
  worker:
    build:
      context: ..
      dockerfile: deploy/docker/worker.Dockerfile
    container_name: {{ cluster_name }}-cluster-worker-local
    env_file: ../.env
    environment:
      - DEBUG=True
      - REDIS_URL=redis://redis:6379/0
      - EMAIL_HOST=mailpit
      - EMAIL_PORT=1025
    volumes:
      - ../src:/app/src
    command: arq src.workers.notification_worker.worker.WorkerSettings
    depends_on:
      - redis
      - mailpit
    networks:
      - {{ cluster_name }}-cluster-local-network

  # --- Mailpit (Email Testing) ---
  mailpit:
    image: axllent/mailpit:latest
    container_name: {{ cluster_name }}-cluster-mailpit-local
    ports:
      - "8025:8025"
      - "1025:1025"
    restart: unless-stopped
    networks:
      - {{ cluster_name }}-cluster-local-network
{% endif %}

  # --- Shared Nginx (Local) ---
  nginx:
    build:
      context: ..
      dockerfile: deploy/nginx/Dockerfile
    container_name: {{ cluster_name }}-cluster-nginx-local
    ports:
      - "8080:80"
    volumes:
      - ./nginx/conf.d:/etc/nginx/conf.d:ro
      - static_local:/app/staticfiles:ro
      - media_local:/app/media:ro
    depends_on:
      - redis
    networks:
      - {{ cluster_name }}-cluster-local-network

volumes:
  static_local:
    name: {{ cluster_name }}_cluster_static_local
  media_local:
    name: {{ cluster_name }}_cluster_media_local

networks:
  {{ cluster_name }}-cluster-local-network:
    name: {{ cluster_name }}-cluster-local-network
    driver: bridge
