# === Local Development Config (HTTP Only) ===

upstream backend_local {
    server backend:8000;
}

server {
    listen 80;
    server_name localhost;

    client_max_body_size 20M;

    # === Static Files ===
    location /static/ {
        alias /app/staticfiles/{{ project_name }}/;
        expires 1y;
        add_header Cache-Control "public, immutable";
    }

    # === Media ===
    location /media/ {
        alias /app/media/{{ project_name }}/;
        expires 1y;
        add_header Cache-Control "public, immutable";
        add_header Access-Control-Allow-Origin "*";
    }

    # === API → Backend ===
    location /api/ {
        proxy_pass http://backend_local;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_connect_timeout 60s;
        proxy_send_timeout 60s;
        proxy_read_timeout 60s;
    }

    # === Swagger / OpenAPI ===
    location /docs {
        proxy_pass http://backend_local;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
    }

    location /openapi.json {
        proxy_pass http://backend_local;
    }

    # === Health ===
    location /health {
        proxy_pass http://backend_local/api/v1/health;
        access_log off;
    }

    # === All other requests → Django Backend ===
    location / {
        proxy_pass http://backend_local;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
