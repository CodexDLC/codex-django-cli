from django.urls import include, path

from .views.users import user_detail_view, users_list_view
{%- if with_booking %}
from .views.booking import cancel_booking_view, my_bookings_view
{%- endif %}

app_name = "cabinet"

urlpatterns = [
    # Codex cabinet library: dashboard + site settings
    path("", include("allauth.urls")),
    path("", include("codex_django.cabinet.urls")),
    # Users
    path("users/", users_list_view, name="users"),
    path("users/<int:pk>/", user_detail_view, name="user_detail"),
{%- if with_booking %}
    # Booking — client portal
    path("my/bookings/", my_bookings_view, name="my_bookings"),
    path("my/bookings/<int:pk>/cancel/", cancel_booking_view, name="cancel_booking"),
{%- endif %}
]
