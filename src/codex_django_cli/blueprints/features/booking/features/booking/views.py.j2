# views.py.j2
from datetime import datetime

from django.utils.dateparse import parse_date
from rest_framework import status
from rest_framework.response import Response
from rest_framework.views import APIView

from .selectors import create_booking, get_available_slots, get_calendar_data, get_nearest_slots


class AvailableSlotsView(APIView):
    def get(self, request):
        service_ids = request.query_params.getlist("service_ids[]")
        target_date_str = request.query_params.get("date")

        if not service_ids or not target_date_str:
            return Response(
                {"error": "service_ids[] and date are required"},
                status=status.HTTP_400_BAD_REQUEST,
            )

        target_date = parse_date(target_date_str)
        if not target_date:
            return Response(
                {"error": "Invalid date format"}, status=status.HTTP_400_BAD_REQUEST
            )

        slots = get_available_slots(
            service_ids=[int(s) for s in service_ids], target_date=target_date
        )
        return Response(slots)


class NearestSlotsView(APIView):
    def get(self, request):
        service_ids = request.query_params.getlist("service_ids[]")
        search_from_str = request.query_params.get("search_from")

        if not service_ids:
            return Response(
                {"error": "service_ids[] is required"},
                status=status.HTTP_400_BAD_REQUEST,
            )

        search_from = parse_date(search_from_str) if search_from_str else datetime.now().date()

        slots = get_nearest_slots(
            service_ids=[int(s) for s in service_ids], search_from=search_from
        )
        return Response(slots)


