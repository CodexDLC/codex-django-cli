"""Scaffold-owned engine gateway for resource-slot booking.

This file is intended to be generated by the booking scaffold. It adapts the
project provider to the stable ``codex_django.booking`` selectors so project
owners can swap model mappings without reimplementing engine orchestration.
"""

from __future__ import annotations

from datetime import date
from typing import Any

from codex_django.booking import BookingEngineGateway, DjangoAvailabilityAdapter
from codex_django.booking.adapters import BookingCacheAdapter
from codex_django.booking.selectors import (
    create_booking as runtime_create_booking,
)
from codex_django.booking.selectors import (
    get_available_slots as runtime_get_available_slots,
)
from codex_django.booking.selectors import (
    get_calendar_data as runtime_get_calendar_data,
)
from codex_django.booking.selectors import (
    get_nearest_slots as runtime_get_nearest_slots,
)

from ..providers import get_booking_project_data_provider


class BookingRuntimeEngineGateway(BookingEngineGateway):
    """Feature-facing engine gateway bound to the active project provider."""

    def __init__(self, provider: Any = None) -> None:
        self.provider = provider or get_booking_project_data_provider()

    def _make_adapter(self) -> DjangoAvailabilityAdapter:
        models = self.provider.get_feature_models()
        return DjangoAvailabilityAdapter(
            master_model=models.master_model,
            appointment_model=models.appointment_model,
            service_model=models.service_model,
            working_day_model=models.working_day_model,
            day_off_model=models.day_off_model,
            booking_settings_model=models.booking_settings_model,
            site_settings_model=models.site_settings_model,
        )

    def get_calendar_data(
        self,
        *,
        year: int,
        month: int,
        today: date | None = None,
        selected_date: date | None = None,
    ) -> list[dict[str, Any]]:
        return runtime_get_calendar_data(year=year, month=month, today=today, selected_date=selected_date)

    def get_available_slots(self, *, service_ids: list[int], target_date: date, **kwargs: Any) -> Any:
        return runtime_get_available_slots(self._make_adapter(), service_ids, target_date, **kwargs)

    def get_nearest_slots(self, *, service_ids: list[int], search_from: date, **kwargs: Any) -> Any:
        return runtime_get_nearest_slots(self._make_adapter(), service_ids, search_from, **kwargs)

    def create_booking(
        self,
        *,
        service_ids: list[int],
        target_date: date,
        selected_time: str,
        master_id: int | None,
        client: Any,
        **kwargs: Any,
    ) -> Any:
        models = self.provider.get_feature_models()
        return runtime_create_booking(
            self._make_adapter(),
            BookingCacheAdapter(),
            models.appointment_model,
            service_ids=service_ids,
            target_date=target_date,
            selected_time=selected_time,
            master_id=master_id or 0,
            client=client,
            **kwargs,
        )


_gateway = BookingRuntimeEngineGateway()


def get_booking_engine_gateway() -> BookingRuntimeEngineGateway:
    """Return the active engine gateway for the booking scaffold."""

    return _gateway





