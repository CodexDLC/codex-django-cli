            return self._build_series_booking_context(mode=mode)

        services = self.provider.get_cabinet_services()
        masters = self.provider.get_cabinet_masters()
        start_date = datetime.strptime("2026-03-23", "%Y-%m-%d").date()
        available_days: list[dict[str, str | int | bool]] = []
        slot_matrix: dict[str, dict[str, list[str]]] = {}
        for offset in range(self.builder_day_horizon):
