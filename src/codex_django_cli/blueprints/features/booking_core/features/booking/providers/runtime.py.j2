"""Scaffold-owned project provider for resource-slot booking.

This file is intended to be generated by the booking scaffold. It binds the
project's concrete Django models and sandbox cabinet data to the stable
runtime contracts exported by ``codex_django.booking``.
"""

from __future__ import annotations

from typing import Any

from codex_django.booking import (
    BookingActionResult,
    BookingCalendarPrefillState,
    BookingFeatureModels,
    BookingProjectDataProvider,
    BookingQuickCreateClientOptionState,
    BookingQuickCreateServiceOptionState,
)
from system.models import SiteSettings

from ..booking_settings import BookingSettings
from ..models import Appointment, Master, MasterDayOff, MasterWorkingDay, Service, ServiceCategory
from . import demo_data


class RuntimeBookingProvider(BookingProjectDataProvider):
    """Default sandbox provider for the resource-slot booking scaffold."""

    def get_feature_models(self) -> BookingFeatureModels:
        return BookingFeatureModels(
            appointment_model=Appointment,
            master_model=Master,
            service_model=Service,
            working_day_model=MasterWorkingDay,
            day_off_model=MasterDayOff,
            booking_settings_model=BookingSettings,
            site_settings_model=SiteSettings,
        )

    def get_service_categories(self) -> Any:
        return ServiceCategory.objects.prefetch_related("services").all()

    def get_cabinet_masters(self) -> list[dict[str, Any]]:
        return demo_data.get_masters()

    def get_cabinet_clients(self) -> list[dict[str, Any]]:
        return demo_data.get_clients()

    def get_cabinet_services(self) -> list[dict[str, Any]]:
        return demo_data.get_services()

    def get_cabinet_appointments(self) -> list[dict[str, Any]]:
        return demo_data.get_appointments()

    def get_schedule_prefill(self, *, schedule_date: str, col: int, row: int) -> BookingCalendarPrefillState:
        master = demo_data.get_master_by_column(col)
        return BookingCalendarPrefillState(
            resource_id=master["id"] if master else None,
            resource_name=master["name"] if master else "Any specialist",
            booking_date=schedule_date,
            start_time=demo_data.get_slot_time(row),
            slot_duration_minutes=30,
            col=col,
            row=row,
        )

    def get_quick_create_services(
        self,
        *,
        resource_id: int | None,
        booking_date: str,
        start_time: str,
    ) -> list[BookingQuickCreateServiceOptionState]:
        del booking_date, start_time
        return [
            BookingQuickCreateServiceOptionState(
                value=str(service["id"]),
                label=service["title"],
                price_label=f"${service['price']}",
                duration_label=f"{service['duration']} min",
            )
            for service in demo_data.get_services_for_master(resource_id)
        ]

    def get_quick_create_clients(self) -> list[BookingQuickCreateClientOptionState]:
        return [
            BookingQuickCreateClientOptionState(
                value=str(client["id"]),
                label=client["name"],
                subtitle=client["phone"],
                email=str(client.get("email", "")),
                search_text=" ".join(
                    part.lower()
                    for part in [
                        str(client.get("name", "")),
                        str(client.get("phone", "")),
                        str(client.get("email", "")),
                    ]
                    if part
                ),
            )
            for client in demo_data.get_clients()
        ]

    def create_quick_client(
        self,
        *,
        first_name: str,
        last_name: str,
        phone: str,
        email: str,
    ) -> dict[str, object]:
        full_name = " ".join(part for part in [first_name.strip(), last_name.strip()] if part).strip()
        return demo_data.create_client(name=full_name or phone or email or "New Client", phone=phone, email=email)

    def get_quick_create_slot_options(self, *, resource_id: int, booking_date: str) -> list[str]:
        return demo_data.get_available_slot_options(resource_id, booking_date)

    def create_quick_appointment(
        self,
        *,
        resource_id: int,
        booking_date: str,
        start_time: str,
        service_id: int,
        client_name: str,
        client_phone: str,
        client_email: str = "",
    ) -> dict[str, object]:
        if not client_name and client_phone:
            client_name = client_phone
        return demo_data.create_appointment(
            master_id=resource_id,
            booking_date=booking_date,
            start_time=start_time,
            service_id=service_id,
            client_name=client_name,
            client_phone=client_phone,
            client_email=client_email,
        )

    def update_quick_appointment(
        self, *, booking_id: int, booking_date: str, start_time: str
    ) -> dict[str, object] | None:
        return demo_data.update_appointment(booking_id, date=booking_date, time=start_time)

    def run_cabinet_action(self, *, booking_id: int, action: str, redirect_url: str) -> BookingActionResult:
        if action == "confirm":
            demo_data.update_appointment(booking_id, status="confirmed")
        elif action == "cancel":
            demo_data.cancel_appointment(booking_id)

        action_messages = {
            "confirm": "Booking confirmed in demo mode.",
            "cancel": "Booking cancelled in demo mode.",
            "reschedule": "Booking rescheduled in demo mode.",
            "create_from_slot": "Booking created in demo mode.",
            "unsupported": "Please select a client before creating the booking.",
        }
        return BookingActionResult(
            ok=action in action_messages and action != "unsupported",
            code=f"booking-{action}",
            message=action_messages.get(action, "Unsupported booking action."),
            ui_effect="reload_modal",
            target_url=redirect_url,
        )


_provider = RuntimeBookingProvider()


def get_booking_project_data_provider() -> RuntimeBookingProvider:
    """Return the active project provider for the booking scaffold."""

    return _provider
